        <rename>current_ar_amount</rename>
        <update>Y</update>
      </value>
      <value>
        <name>past_due_amount</name>
        <rename>past_due_amount</rename>
        <update>Y</update>
      </value>
      <value>
        <name>receivable_outstanding_ratio</name>
        <rename>receivable_outstanding_ratio</rename>
        <update>Y</update>
      </value>
      <value>
        <name>current_ar_ratio</name>
        <rename>current_ar_ratio</rename>
        <update>Y</update>
      </value>
      <value>
        <name>average_days_to_collect</name>
        <rename>average_days_to_collect</rename>
        <update>Y</update>
