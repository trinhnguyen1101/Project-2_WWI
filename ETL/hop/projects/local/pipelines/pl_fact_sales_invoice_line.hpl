        <name>bill_to_customer_key</name>
        <rename>bill_to_customer_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>product_key</name>
        <rename>product_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>package_type_key</name>
