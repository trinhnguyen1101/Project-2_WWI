  <transform>
    <name>Read invoice lines</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>SELECT
    line.invoice_line_id AS source_invoice_line_id,
    line.invoice_id AS source_invoice_id,
    TO_CHAR(invoice.invoice_date, 'YYYYMMDD')::integer AS invoice_date_key,
    invoice.customer_id,
    invoice.bill_to_customer_id,
    line.stock_item_id,
    line.package_type_id,
    invoice.salesperson_person_id,
    line.quantity::numeric AS quantity_sold,
    (line.extended_price - line.tax_amount)::numeric(18,2) AS revenue_ex_tax,
    line.tax_amount::numeric(18,2) AS tax_amount,
    line.extended_price::numeric(18,2) AS revenue_inc_tax,
    line.line_profit::numeric(18,2) AS gross_profit,
    ((line.extended_price - line.tax_amount) - line.line_profit)::numeric(18,2) AS estimated_cogs,
    (line.line_profit / NULLIF(line.extended_price - line.tax_amount, 0))::numeric(18,6) AS gross_margin_pct,
    ((line.extended_price - line.tax_amount) / NULLIF(line.quantity, 0))::numeric(18,6)
        AS average_selling_price_ex_tax,
    (line.line_profit / NULLIF(line.quantity, 0))::numeric(18,6) AS profit_per_unit
FROM staging.stg_sales_invoice_lines line
JOIN staging.stg_sales_invoices invoice
  ON invoice.invoice_id = line.invoice_id
WHERE '${VALIDATE_ONLY}' &lt;&gt; 'Y'
ORDER BY line.invoice_line_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>96</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
