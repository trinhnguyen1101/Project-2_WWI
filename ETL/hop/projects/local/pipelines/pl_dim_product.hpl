<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_product</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load products and resolve supplier and package type surrogate keys.</description>
    <extended_description>Load products and resolve supplier and package type surrogate keys.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters />
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/15 10:45:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/15 10:45:00.000</modified_date>
  </info>
  <notepads />
  <order>
    <hop>
      <from>Read product rows</from>
      <to>Lookup supplier_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup supplier_key</from>
      <to>Lookup unit_package_type_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup unit_package_type_key</from>
      <to>Lookup outer_package_type_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup outer_package_type_key</from>
      <to>Upsert dim_product</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read product rows</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>SELECT
    stock_item_id AS source_stock_item_id,
    stock_item_name,
    supplier_id,
    color_name_for_analysis AS color_name,
    unit_package_id,
    outer_package_id,
    brand_for_analysis AS brand,
    size_for_analysis AS size,
    lead_time_days,
    quantity_per_outer,
    is_chiller_stock,
    tax_rate,
    unit_price AS current_unit_price,
    recommended_retail_price,
    typical_weight_per_unit,
    country_of_manufacture,
    tags_for_analysis AS tags
FROM staging.stg_warehouse_stock_items
ORDER BY stock_item_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup supplier_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>supplier_id</name>
        <field>source_supplier_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>supplier_key</rename>
        <name>supplier_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_supplier</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>352</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup unit_package_type_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>unit_package_id</name>
        <field>source_package_type_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>unit_package_type_key</rename>
        <name>package_type_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_package_type</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>576</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup outer_package_type_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>outer_package_id</name>
        <field>source_package_type_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>outer_package_type_key</rename>
        <name>package_type_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_package_type</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>800</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Upsert dim_product</name>
    <type>InsertUpdate</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_dwh</connection>
    <commit>1000</commit>
    <update_bypassed>N</update_bypassed>
    <lookup>
      <schema>dwh</schema>
      <table>dim_product</table>
      <key>
        <name>source_stock_item_id</name>
        <field>source_stock_item_id</field>
        <condition>=</condition>
        <name2 />
      </key>
      <value>
        <name>source_stock_item_id</name>
        <rename>source_stock_item_id</rename>
        <update>N</update>
      </value>
      <value>
        <name>stock_item_name</name>
        <rename>stock_item_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>supplier_key</name>
        <rename>supplier_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>color_name</name>
        <rename>color_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>unit_package_type_key</name>
        <rename>unit_package_type_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>outer_package_type_key</name>
        <rename>outer_package_type_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>brand</name>
        <rename>brand</rename>
        <update>Y</update>
      </value>
      <value>
        <name>size</name>
        <rename>size</rename>
        <update>Y</update>
      </value>
      <value>
        <name>lead_time_days</name>
        <rename>lead_time_days</rename>
        <update>Y</update>
      </value>
      <value>
        <name>quantity_per_outer</name>
        <rename>quantity_per_outer</rename>
        <update>Y</update>
      </value>
      <value>
        <name>is_chiller_stock</name>
        <rename>is_chiller_stock</rename>
        <update>Y</update>
      </value>
      <value>
        <name>tax_rate</name>
        <rename>tax_rate</rename>
        <update>Y</update>
      </value>
      <value>
        <name>current_unit_price</name>
        <rename>current_unit_price</rename>
        <update>Y</update>
      </value>
      <value>
        <name>recommended_retail_price</name>
        <rename>recommended_retail_price</rename>
        <update>Y</update>
      </value>
      <value>
        <name>typical_weight_per_unit</name>
        <rename>typical_weight_per_unit</rename>
        <update>Y</update>
      </value>
      <value>
        <name>country_of_manufacture</name>
        <rename>country_of_manufacture</rename>
        <update>Y</update>
      </value>
      <value>
        <name>tags</name>
        <rename>tags</rename>
        <update>Y</update>
      </value>
    </lookup>
    <attributes />
    <GUI>
      <xloc>1024</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform_error_handling />
  <attributes />
</pipeline>
