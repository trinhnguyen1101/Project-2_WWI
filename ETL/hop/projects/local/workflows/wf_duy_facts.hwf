      <name>ETL_AS_OF_DATE</name>
      <description>Snapshot date for open customer transaction aging.</description>
      <default_value>2016-05-31</default_value>
    </parameter>
  </parameters>
  <actions>
    <action>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <intervalSeconds>0</intervalSeconds>
      <intervalMinutes>60</intervalMinutes>
      <DayOfMonth>1</DayOfMonth>
