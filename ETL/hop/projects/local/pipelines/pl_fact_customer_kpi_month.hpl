      <value>
        <name>average_collection_age_days</name>
        <rename>average_collection_age_days</rename>
        <update>Y</update>
      </value>
      <value>
        <name>average_days_past_due</name>
        <rename>average_days_past_due</rename>
        <update>Y</update>
      </value>
      <value>
        <name>overdue_transaction_rate</name>
        <rename>overdue_transaction_rate</rename>
        <update>Y</update>
      </value>
    </lookup>
    <attributes />
