<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_customer</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load customers and resolve lookup surrogate keys for categories, buying groups, methods, and cities.</description>
    <extended_description>Load customers and resolve lookup surrogate keys for categories, buying groups, methods, and cities.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters />
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/18 00:00:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/18 00:00:00.000</modified_date>
  </info>
  <notepads />
  <order>
    <hop>
      <from>Read customer rows</from>
      <to>Lookup customer_category_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup customer_category_key</from>
      <to>Lookup buying_group_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup buying_group_key</from>
      <to>Lookup delivery_method_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup delivery_method_key</from>
      <to>Lookup delivery_city_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup delivery_city_key</from>
      <to>Lookup postal_city_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup postal_city_key</from>
      <to>Upsert dim_customer</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read customer rows</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>SELECT
    customer_id AS source_customer_id,
    customer_name,
    customer_category_id,
    buying_group_id,
    delivery_method_id,
    delivery_city_id,
    postal_city_id,
    credit_limit,
    account_opened_date,
    standard_discount_percentage,
    is_statement_sent,
    is_on_credit_hold,
    payment_days,
    phone_number,
    website_url
FROM staging.stg_sales_customers
ORDER BY customer_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup customer_category_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>customer_category_id</name>
        <field>source_customer_category_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>customer_category_key</rename>
        <name>customer_category_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_customer_category</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>352</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
