<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_check_fact_dependencies</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Fail before fact loading when dimensions owned by the other ETL stream are empty.</description>
    <extended_description>Fail before fact loading when dimensions owned by the other ETL stream are empty.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters />
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/13 00:00:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/13 00:00:00.000</modified_date>
  </info>
  <notepads />
  <order>
    <hop>
      <from>Check dependency counts</from>
      <to>Are dependencies ready?</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Are dependencies ready?</from>
      <to>Dependencies ready</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Are dependencies ready?</from>
      <to>Missing dependencies</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Check dependency counts</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_dwh</connection>
    <sql>SELECT (
  (SELECT COUNT(*) FROM dwh.dim_customer) &gt; 0
   AND (SELECT COUNT(*) FROM dwh.dim_product) &gt; 0
   AND (SELECT COUNT(*) FROM dwh.dim_package_type) &gt; 0
   AND (SELECT COUNT(*) FROM dwh.dim_person) &gt; 0
   AND (SELECT COUNT(*) FROM dwh.dim_transaction_type) &gt; 0
) AS dependencies_ready</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Are dependencies ready?</name>
    <type>FilterRows</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <send_true_to>Dependencies ready</send_true_to>
    <send_false_to>Missing dependencies</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>dependencies_ready</leftvalue>
        <function>=</function>
        <rightvalue />
        <value>
          <name>constant</name>
          <type>Boolean</type>
          <text>Y</text>
          <length>-1</length>
          <precision>-1</precision>
          <isnull>N</isnull>
          <mask />
        </value>
      </condition>
    </compare>
    <attributes />
    <GUI>
      <xloc>384</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Dependencies ready</name>
    <type>Dummy</type>
    <description>The required dimensions contain data; fact loading may start.</description>
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <attributes />
    <GUI>
      <xloc>672</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Missing dependencies</name>
    <type>Abort</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <always_log_rows>Y</always_log_rows>
    <message>Fact load stopped: dim_customer, dim_product, dim_package_type, dim_person, and dim_transaction_type must be loaded first.</message>
    <row_threshold>0</row_threshold>
    <attributes />
    <GUI>
      <xloc>672</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform_error_handling />
  <attributes />
</pipeline>
