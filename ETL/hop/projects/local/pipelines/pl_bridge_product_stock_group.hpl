<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <pipeline_version>1.0</pipeline_version>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters/>
    <name>pl_bridge_product_stock_group</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load product / stock group bridge relationships.</description>
    <extended_description>Load product / stock group bridge relationships.</extended_description>
    <created_user>Codex</created_user>
    <modified_user>Codex</modified_user>
    <created_date>2026/06/16 11:00:00.000</created_date>
    <modified_date>2026/06/16 11:00:00.000</modified_date>
  </info>
  <transform>
    <type>TableInput</type>
    <name>Read bridge rows</name>
    <sql>SELECT
    stock_item_id AS source_stock_item_id,
    stock_group_id AS source_stock_group_id
FROM staging.stg_warehouse_stock_item_stock_groups
ORDER BY stock_item_stock_group_id</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <connection>postgres_staging</connection>
    <lookup/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>DBLookup</type>
    <name>Lookup product_key</name>
    <connection>postgres_dwh</connection>
    <cache>Y</cache>
    <cache_size>0</cache_size>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <table>dim_product</table>
      <key>
        <name>source_stock_item_id</name>
        <condition>=</condition>
        <field>source_stock_item_id</field>
      </key>
      <value>
        <name>product_key</name>
        <rename>product_key</rename>
        <type>Integer</type>
        <trim_type>none</trim_type>
      </value>
      <fail_on_multiple>Y</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
    </lookup>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>352</xloc>
      <yloc>96</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>DBLookup</type>
    <name>Lookup stock_group_key</name>
    <connection>postgres_dwh</connection>
    <cache>Y</cache>
    <cache_size>0</cache_size>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <table>dim_stock_group</table>
      <key>
        <name>source_stock_group_id</name>
        <condition>=</condition>
        <field>source_stock_group_id</field>
      </key>
      <value>
        <name>stock_group_key</name>
        <rename>stock_group_key</rename>
        <type>Integer</type>
        <trim_type>none</trim_type>
      </value>
      <fail_on_multiple>Y</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
    </lookup>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>576</xloc>
      <yloc>96</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>InsertUpdate</type>
    <name>Upsert bridge_product_stock_group</name>
    <lookup>
      <key>
        <name>product_key</name>
        <field>product_key</field>
        <condition>=</condition>
        <name2/>
      </key>
      <key>
        <name>stock_group_key</name>
        <field>stock_group_key</field>
        <condition>=</condition>
        <name2/>
      </key>
      <value>
        <name>product_key</name>
        <rename>product_key</rename>
        <update>N</update>
      </value>
      <value>
        <name>stock_group_key</name>
        <rename>stock_group_key</rename>
        <update>N</update>
      </value>
      <schema>dwh</schema>
      <table>bridge_product_stock_group</table>
    </lookup>
    <commit>1000</commit>
    <update_bypassed>N</update_bypassed>
    <connection>postgres_dwh</connection>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>800</xloc>
      <yloc>96</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Read bridge rows</from>
      <to>Lookup product_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup product_key</from>
      <to>Lookup stock_group_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup stock_group_key</from>
      <to>Upsert bridge_product_stock_group</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
