<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_fact_customer_transaction</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load customer receivable transactions and deterministic aging measures.</description>
    <extended_description>Load customer receivable transactions and deterministic aging measures.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>ETL_AS_OF_DATE</name>
        <default_value>2016-05-31</default_value>
        <description>Snapshot date used for open-transaction aging (YYYY-MM-DD).</description>
      </parameter>
      <parameter>
        <name>VALIDATE_ONLY</name>
        <default_value>N</default_value>
        <description>Set to Y to initialize and validate the pipeline without loading rows.</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/13 00:00:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/13 00:00:00.000</modified_date>
  </info>
