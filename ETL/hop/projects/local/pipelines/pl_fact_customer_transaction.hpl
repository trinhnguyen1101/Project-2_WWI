      <to>Lookup payment_method_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup payment_method_key</from>
      <to>Lookup transaction_type_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup transaction_type_key</from>
      <to>Upsert fact_customer_transaction</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
