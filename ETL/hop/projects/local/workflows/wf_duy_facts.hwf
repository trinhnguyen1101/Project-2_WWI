<?xml version="1.0" encoding="UTF-8"?>
<workflow>
  <name>wf_duy_facts</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Check shared dimensions, then run all facts assigned to Duy.</description>
  <extended_description>Check shared dimensions, then run all facts assigned to Duy.</extended_description>
  <created_user>Codex</created_user>
