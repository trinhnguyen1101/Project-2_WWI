  <transform>
    <name>Read order lines</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>SELECT
    line.order_line_id AS source_order_line_id,
    line.order_id AS source_order_id,
    TO_CHAR(orders.order_date, 'YYYYMMDD')::integer AS order_date_key,
    TO_CHAR(orders.expected_delivery_date, 'YYYYMMDD')::integer AS expected_delivery_date_key,
    CASE
      WHEN line.picking_completed_when IS NULL THEN NULL
      ELSE TO_CHAR(line.picking_completed_when::date, 'YYYYMMDD')::integer
    END AS picking_completed_date_key,
    orders.customer_id,
    line.stock_item_id,
    line.package_type_id,
    orders.salesperson_person_id,
    orders.picked_by_person_id,
    line.quantity::numeric AS ordered_quantity,
    line.picked_quantity::numeric AS picked_quantity,
    COALESCE(line.unpicked_quantity, line.quantity - line.picked_quantity)::numeric AS unpicked_quantity,
    COALESCE(
      line.fill_rate,
      line.picked_quantity::numeric / NULLIF(line.quantity, 0)
    )::numeric(18,6) AS fill_rate,
    CASE
      WHEN line.picking_completed_when IS NULL THEN NULL
      ELSE (
        EXTRACT(EPOCH FROM (line.picking_completed_when - orders.order_date::timestamp)) / 3600
      )::numeric(18,6)
    END AS picking_lead_time_hours,
    (orders.expected_delivery_date - orders.order_date)::integer AS expected_delivery_lead_days,
    orders.is_undersupply_backordered,
    COALESCE(line.is_fully_picked, line.picked_quantity &gt;= line.quantity) AS is_fully_picked
FROM staging.stg_sales_order_lines line
JOIN staging.stg_sales_orders orders
  ON orders.order_id = line.order_id
WHERE '${VALIDATE_ONLY}' &lt;&gt; 'Y'
ORDER BY line.order_line_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>96</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
