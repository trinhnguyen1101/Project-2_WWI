<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_supplier</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load suppliers and resolve delivery/postal city and delivery method surrogate keys.</description>
    <extended_description>Load suppliers and resolve delivery/postal city and delivery method surrogate keys.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters />
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/18 00:00:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/18 00:00:00.000</modified_date>
  </info>
  <notepads />
  <order>
    <hop>
      <from>Read supplier rows</from>
      <to>Lookup delivery_city_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup delivery_city_key</from>
      <to>Lookup postal_city_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup postal_city_key</from>
      <to>Lookup delivery_method_key</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup delivery_method_key</from>
      <to>Upsert dim_supplier</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read supplier rows</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>SELECT
    s.supplier_id AS source_supplier_id,
    s.supplier_name,
    c.supplier_category_name,
    s.delivery_city_id,
    s.postal_city_id,
    s.delivery_method_id,
    s.payment_days,
    s.phone_number,
    s.website_url
FROM staging.stg_purchasing_suppliers AS s
LEFT JOIN staging.stg_purchasing_supplier_categories AS c
  ON s.supplier_category_id = c.supplier_category_id
ORDER BY s.supplier_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup delivery_city_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>delivery_city_id</name>
        <field>source_city_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>delivery_city_key</rename>
        <name>city_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_city</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>352</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup postal_city_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>postal_city_id</name>
        <field>source_city_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>postal_city_key</rename>
        <name>city_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_city</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>576</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Lookup delivery_method_key</name>
    <type>DBLookup</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <cache_size>0</cache_size>
    <cache>Y</cache>
    <connection>postgres_dwh</connection>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <schema>dwh</schema>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>Y</fail_on_multiple>
      <key>
        <condition>=</condition>
        <name>delivery_method_id</name>
        <field>source_delivery_method_id</field>
      </key>
      <value>
        <type>Integer</type>
        <rename>delivery_method_key</rename>
        <name>delivery_method_key</name>
        <trim_type>none</trim_type>
      </value>
      <table>dim_delivery_method</table>
    </lookup>
    <attributes />
    <GUI>
      <xloc>800</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Upsert dim_supplier</name>
    <type>InsertUpdate</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_dwh</connection>
    <commit>1000</commit>
    <update_bypassed>N</update_bypassed>
    <lookup>
      <schema>dwh</schema>
      <table>dim_supplier</table>
      <key>
        <name>source_supplier_id</name>
        <field>source_supplier_id</field>
        <condition>=</condition>
        <name2 />
      </key>
      <value>
        <name>source_supplier_id</name>
        <rename>source_supplier_id</rename>
        <update>N</update>
      </value>
      <value>
        <name>supplier_name</name>
        <rename>supplier_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>supplier_category_name</name>
        <rename>supplier_category_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>delivery_city_key</name>
        <rename>delivery_city_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>postal_city_key</name>
        <rename>postal_city_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>delivery_method_key</name>
        <rename>delivery_method_key</rename>
        <update>Y</update>
      </value>
      <value>
        <name>payment_days</name>
        <rename>payment_days</rename>
        <update>Y</update>
      </value>
      <value>
        <name>phone_number</name>
        <rename>phone_number</rename>
        <update>Y</update>
      </value>
      <value>
        <name>website_url</name>
        <rename>website_url</rename>
        <update>Y</update>
      </value>
    </lookup>
    <attributes />
    <GUI>
      <xloc>1024</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform_error_handling />
  <attributes />
</pipeline>
