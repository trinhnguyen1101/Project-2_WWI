    </lookup>
    <attributes />
    <GUI>
      <xloc>768</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Read customer transactions</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_staging</connection>
    <sql>WITH source_rows AS (
    SELECT
        txn.*,
        customer.payment_days,
        (txn.transaction_date + customer.payment_days)::date AS due_date,
        COALESCE(txn.finalization_date, '${ETL_AS_OF_DATE}'::date) AS aging_date
    FROM staging.stg_sales_customer_transactions txn
    JOIN staging.stg_sales_customers customer
      ON customer.customer_id = txn.customer_id
)
SELECT
    customer_transaction_id AS source_customer_transaction_id,
    invoice_id AS source_invoice_id,
    TO_CHAR(transaction_date, 'YYYYMMDD')::integer AS transaction_date_key,
    CASE
      WHEN finalization_date IS NULL THEN NULL
      ELSE TO_CHAR(finalization_date, 'YYYYMMDD')::integer
    END AS finalization_date_key,
    TO_CHAR(due_date, 'YYYYMMDD')::integer AS due_date_key,
    customer_id,
    payment_method_id,
    transaction_type_id,
    amount_excluding_tax::numeric(18,2) AS receivable_ex_tax,
    tax_amount::numeric(18,2) AS receivable_tax_amount,
    transaction_amount::numeric(18,2) AS receivable_inc_tax,
    outstanding_balance::numeric(18,2) AS outstanding_amount,
    COALESCE(paid_amount, transaction_amount - outstanding_balance)::numeric(18,2) AS paid_amount,
    COALESCE(
      outstanding_ratio,
      outstanding_balance / NULLIF(transaction_amount, 0)
    )::numeric(18,6) AS outstanding_ratio,
    CASE
      WHEN finalization_date IS NULL THEN NULL
      ELSE (finalization_date - transaction_date)::integer
    END AS days_to_collect,
    (aging_date - transaction_date)::integer AS collection_age_days,
    GREATEST((aging_date - due_date)::integer, 0) AS days_past_due,
    CASE
      WHEN outstanding_balance &gt; 0 AND aging_date &lt;= due_date
      THEN outstanding_balance ELSE 0
    END::numeric(18,2) AS current_ar_amount,
    CASE
      WHEN outstanding_balance &gt; 0 AND aging_date &gt; due_date
      THEN outstanding_balance ELSE 0
    END::numeric(18,2) AS past_due_amount,
    COALESCE(is_finalized_flag, is_finalized, FALSE) AS is_finalized,
    (aging_date &gt; due_date) AS is_overdue
FROM source_rows
WHERE '${VALIDATE_ONLY}' &lt;&gt; 'Y'
ORDER BY customer_transaction_id</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>96</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Upsert fact_customer_transaction</name>
    <type>InsertUpdate</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
