<?xml version="1.0" encoding="UTF-8"?>
  <pipeline>
    <info>
      <name>pl_dim_city</name>
      <name_sync_with_filename>Y</name_sync_with_filename>
      <description>Load cities and resolve state/province surrogate keys.</description>
      <extended_description>Load cities and resolve state/province surrogate keys.</extended_description>
      <pipeline_version>1.0</pipeline_version>
      <pipeline_type>Normal</pipeline_type>
      <pipeline_status>0</pipeline_status>
      <parameters />
      <capture_transform_performance>N</capture_transform_performance>
      <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
      <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
      <created_user>Codex</created_user>
      <created_date>2026/06/13 00:00:00.000</created_date>
      <modified_user>Codex</modified_user>
      <modified_date>2026/06/13 00:00:00.000</modified_date>
    </info>
    <notepads />
    <order>
      <hop>
        <from>Read cities</from>
        <to>Lookup state_province_key</to>
        <enabled>Y</enabled>
      </hop>
      <hop>
        <from>Lookup state_province_key</from>
        <to>Upsert dim_city</to>
        <enabled>Y</enabled>
      </hop>
    </order>
    <transform>
      <name>Read cities</name>
      <type>TableInput</type>
      <description />
      <distribute>Y</distribute>
      <custom_distribution />
      <copies>1</copies>
      <partitioning>
        <method>none</method>
        <schema_name />
      </partitioning>
      <connection>postgres_staging</connection>
      <sql>SELECT
      city_id AS source_city_id,
      state_province_id,
      city_name,
      latest_recorded_population
  FROM staging.stg_application_cities
  ORDER BY city_id</sql>
      <limit>0</limit>
      <lookup />
      <execute_each_row>N</execute_each_row>
      <variables_active>Y</variables_active>
      <attributes />
      <GUI>
        <xloc>96</xloc>
        <yloc>144</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Lookup state_province_key</name>
      <type>DBLookup</type>
      <description />
      <distribute>Y</distribute>
      <custom_distribution />
      <copies>1</copies>
      <partitioning>
        <method>none</method>
        <schema_name />
      </partitioning>
      <cache_size>0</cache_size>
      <cache>Y</cache>
      <connection>postgres_dwh</connection>
      <cache_load_all>Y</cache_load_all>
      <lookup>
        <schema>dwh</schema>
        <eat_row_on_failure>N</eat_row_on_failure>
        <fail_on_multiple>Y</fail_on_multiple>
        <key>
          <condition>=</condition>
          <name>state_province_id</name>
          <field>source_state_province_id</field>
        </key>
        <value>
          <type>Integer</type>
          <rename>state_province_key</rename>
          <name>state_province_key</name>
          <trim_type>none</trim_type>
        </value>
        <table>dim_state_province</table>
      </lookup>
      <attributes />
      <GUI>
        <xloc>352</xloc>
        <yloc>144</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Upsert dim_city</name>
      <type>InsertUpdate</type>
      <description />
      <distribute>Y</distribute>
      <custom_distribution />
      <copies>1</copies>
      <partitioning>
        <method>none</method>
        <schema_name />
      </partitioning>
      <connection>postgres_dwh</connection>
      <commit>5000</commit>
      <update_bypassed>N</update_bypassed>
      <lookup>
        <schema>dwh</schema>
        <table>dim_city</table>
        <key>
          <name>source_city_id</name>
          <field>source_city_id</field>
          <condition>=</condition>
          <name2 />
        </key>
        <value>
          <name>source_city_id</name>
          <rename>source_city_id</rename>
          <update>N</update>
        </value>
        <value>
          <name>state_province_key</name>
          <rename>state_province_key</rename>
          <update>Y</update>
        </value>
        <value>
          <name>city_name</name>
          <rename>city_name</rename>
          <update>Y</update>
        </value>
        <value>
          <name>latest_recorded_population</name>
          <rename>latest_recorded_population</rename>
          <update>Y</update>
        </value>
      </lookup>
      <attributes />
      <GUI>
        <xloc>640</xloc>
        <yloc>144</yloc>
      </GUI>
    </transform>
    <transform_error_handling />
    <attributes />
  </pipeline>
