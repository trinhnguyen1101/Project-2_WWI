<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_date</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Generate and upsert the DWH date dimension.</description>
    <extended_description>Generate and upsert the DWH date dimension.</extended_description>
    <pipeline_version>1.0</pipeline_version>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>START_DATE</name>
        <default_value>2013-01-01</default_value>
        <description>First date, inclusive (YYYY-MM-DD).</description>
      </parameter>
      <parameter>
        <name>END_DATE</name>
        <default_value>2016-12-31</default_value>
        <description>Last date, inclusive (YYYY-MM-DD).</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>Codex</created_user>
    <created_date>2026/06/13 00:00:00.000</created_date>
    <modified_user>Codex</modified_user>
    <modified_date>2026/06/13 00:00:00.000</modified_date>
  </info>
  <notepads />
  <order>
    <hop>
      <from>Generate date rows</from>
      <to>Upsert dim_date</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Generate date rows</name>
    <type>TableInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_dwh</connection>
    <sql>SELECT
    TO_CHAR(d.full_date, 'YYYYMMDD')::integer AS date_key,
    d.full_date::date AS full_date,
    EXTRACT(DAY FROM d.full_date)::smallint AS day_of_month,
    EXTRACT(MONTH FROM d.full_date)::smallint AS month_number,
    TRIM(TO_CHAR(d.full_date, 'Month')) AS month_name,
    EXTRACT(QUARTER FROM d.full_date)::smallint AS quarter_number,
    EXTRACT(YEAR FROM d.full_date)::smallint AS year_number,
    EXTRACT(ISODOW FROM d.full_date)::smallint AS day_of_week_number,
    TRIM(TO_CHAR(d.full_date, 'Day')) AS day_of_week_name,
    EXTRACT(ISODOW FROM d.full_date) IN (6, 7) AS is_weekend
FROM generate_series(
    '${START_DATE}'::date,
    '${END_DATE}'::date,
    INTERVAL '1 day'
) AS d(full_date)
ORDER BY d.full_date</sql>
    <limit>0</limit>
    <lookup />
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <attributes />
    <GUI>
      <xloc>128</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Upsert dim_date</name>
    <type>InsertUpdate</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name />
    </partitioning>
    <connection>postgres_dwh</connection>
    <commit>1000</commit>
    <update_bypassed>N</update_bypassed>
    <lookup>
      <schema>dwh</schema>
      <table>dim_date</table>
      <key>
        <name>date_key</name>
        <field>date_key</field>
        <condition>=</condition>
        <name2 />
      </key>
      <value>
        <name>date_key</name>
        <rename>date_key</rename>
        <update>N</update>
      </value>
      <value>
        <name>full_date</name>
        <rename>full_date</rename>
        <update>Y</update>
      </value>
      <value>
        <name>day_of_month</name>
        <rename>day_of_month</rename>
        <update>Y</update>
      </value>
      <value>
        <name>month_number</name>
        <rename>month_number</rename>
        <update>Y</update>
      </value>
      <value>
        <name>month_name</name>
        <rename>month_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>quarter_number</name>
        <rename>quarter_number</rename>
        <update>Y</update>
      </value>
      <value>
        <name>year_number</name>
        <rename>year_number</rename>
        <update>Y</update>
      </value>
      <value>
        <name>day_of_week_number</name>
        <rename>day_of_week_number</rename>
        <update>Y</update>
      </value>
      <value>
        <name>day_of_week_name</name>
        <rename>day_of_week_name</rename>
        <update>Y</update>
      </value>
      <value>
        <name>is_weekend</name>
        <rename>is_weekend</rename>
        <update>Y</update>
      </value>
    </lookup>
    <attributes />
    <GUI>
      <xloc>448</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform_error_handling />
  <attributes />
</pipeline>
